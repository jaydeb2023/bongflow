# ============================================
# BongoFlow AI — Environment Variables
# Copy to .env.local and fill in your values
# ============================================

# ---- SUPABASE ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ---- OPENAI / AI BRAIN ----
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY
# OR use Claude:
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY

# ---- BHASHINI (Bengali STT/TTS) ----
BHASHINI_API_KEY=YOUR_BHASHINI_KEY
BHASHINI_USER_ID=YOUR_BHASHINI_USER_ID
BHASHINI_PIPELINE_ID=YOUR_BHASHINI_PIPELINE_ID

# ---- SARVAM AI (Bengali TTS fallback) ----
SARVAM_API_KEY=YOUR_SARVAM_KEY

# ---- WHATSAPP BUSINESS API (AiSensy / Wati) ----
WHATSAPP_API_KEY=YOUR_WHATSAPP_API_KEY
WHATSAPP_API_URL=https://backend.aisensy.com/campaign/t1/api
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WHATSAPP_VERIFY_TOKEN=bongoflow_verify_2024
WHATSAPP_BUSINESS_ACCOUNT_ID=YOUR_WABA_ID

# ---- RAZORPAY (Payments + Invoices) ----
RAZORPAY_KEY_ID=rzp_live_YOUR_KEY
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_YOUR_KEY

# ---- TWILIO (Voice Calling Agent) ----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=+91XXXXXXXXXX
TWILIO_TWIML_APP_SID=YOUR_TWIML_APP_SID

# ---- APP ----
NEXTAUTH_SECRET=your-random-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- MISC ----
GST_BUSINESS_NAME=YOUR_BUSINESS_NAME
GST_NUMBER=YOUR_GST_NUMBER
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
